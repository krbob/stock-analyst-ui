# Vite always sends browser API calls to same-origin /api and proxies them to
# http://localhost:8080 in development. There is no client-side API URL setting.

# Set to false in .env.local to hide the local development attribution footer.
# VITE_SHOW_CHART_ATTRIBUTION=false

# Optional root-relative or absolute http(s) URL shown by the app switcher.
# VITE_PORTFOLIO_URL=/portfolio
