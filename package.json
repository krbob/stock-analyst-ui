{
  "name": "stock-analyst-ui",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "24.18.x",
    "npm": "11.16.x"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run supply-chain:check && npm run contract:check && npm run tokens:check && tsc -b && vite build",
    "contract:check": "node scripts/openapi-contract.mjs check",
    "contract:generate": "node scripts/openapi-contract.mjs generate",
    "contract:test": "node --test scripts/test-openapi-contract.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run contract:test && npm run tokens:check && vitest run",
    "test:coverage": "npm run contract:test && npm run tokens:check && vitest run --coverage",
    "coverage:report": "node scripts/report-coverage.mjs",
    "test:watch": "vitest",
    "test:e2e:ci": "playwright test e2e/accessibility.spec.ts e2e/app-switcher.spec.ts e2e/mobile.spec.ts e2e/offline.spec.ts e2e/request-fanout.spec.ts",
    "tokens:check": "node scripts/validate-design-tokens.mjs",
    "screenshots": "playwright test e2e/screenshots.spec.ts",
    "supply-chain:check": "node scripts/check-supply-chain.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "^10.0.0",
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "js-yaml": "5.2.1"
  }
}
